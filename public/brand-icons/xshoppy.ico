<body>
	<!-- header html -->
	<div class="header">
		<div class="section-screen">
			<div class="nav-mobile md:hidden">
				<div id="menuButton" class="nav-mobile-icon hover:cursor-pointer">
					<svstg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
						roke="currentColor" class="w-6 h-6">
						<path stroke-linecap="round" stroke-linejoin="round"
							d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5" />
						</svg>
				</div>
			</div>
			<div class="logo hidden md:block"><img class="m-0" src="./assets/image/xlog.png" /></div>
			<div class="nav flex-1 hidden md:block">
				<ul class="list-none flex ">
					<li class="px-3">
						<a class="text-lg hover:underline hover:text-blue-600" href="/index.html">产品&服务</a>
					</li>
					<li class="px-3">
						<a class="text-lg hover:underline hover:text-blue-600" href="/price.html">价格</a>
					</li>
				</ul>
			</div>
			<div class="oper flex justify-end">
				<button
					class="button blue whitespace-nowrap flex items-center justify-center box-border consultNow">立即咨询</button>
			</div>
		</div>
	</div>
	<!-- 侧边栏菜单 -->
	<div class="md:hidden -translate-x-full bg-white w-full space-y-6 py-7 px-2 top-12 fixed z-20 inset-y-0 left-0 transform md:relative md:translate-x-0 transition-transform duration-200 ease-in-out"
		id="menu">
		<nav>
			<a href="/" class="block py-2.5 px-4 rounded transition duration-200 hover:underline">产品&服务</a>
			<a href="/price.html" class="block py-2.5 px-4 rounded transition duration-200 hover:underline">价格</a>
		</nav>
	</div>
	<!-- header html -->

	<!-- banner html -->
	<div class="banner">
		<div class="section-screen">
			<div class="text animate__slideInLeft">
				<div class="title">
					快速创建跨境独立站<label></label>
				</div>
				<div class="title">
					<label>省心开店, 直连全球</label>
				</div>
				<div class="describe">
					<p>专属解决方案，满足各类客户需求</p>
				</div>
				<button class="button blue consultNow">立即咨询</button>
			</div>
			<div class="image animate__slideInRight">
				<picture>
					<source media="(max-width: 768px)" srcset="./assets/image/banner-wap-pop.png">
					<img src="./assets/image/banner-pop.png">
				</picture>
				<!-- <img src="./assets/image/banner-pop.png" /> -->
			</div>
		</div>
	</div>
