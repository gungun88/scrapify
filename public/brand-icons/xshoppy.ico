	<!-- intended for html -->

	<div class="section-column white">
		<div class="section-screen">
			<h3 class="title">开通流程</h3>
			<div class="section-grid">
				<div class="section-grid-item">
					<div class="image"><img src="./assets/image/sellers.png" /></div>
					<div class="subtitle">申请开通</div>
					<div class="describe">点击页面左上角,添加专属客户经理</div>
				</div>
				<div class="section-grid-item">
					<div class="image"><img src="./assets/image/platform.png" /></div>
					<div class="subtitle">开店需求</div>
					<div class="describe">与客户经理，沟通开店需求或开店数量</div>
				</div>
				<div class="section-grid-item">
					<div class="image"><img src="./assets/image/personalized.png" /></div>
					<div class="subtitle">完成开店</div>
					<div class="describe">客户经理授权店铺数量并给到帐号</div>
				</div>
			</div>
		</div>
	</div>

	<!-- intended for html -->

	<!-- Quick experience html -->
	<div class="section-column blue">
		<div class="section-screen">
			<h3 class="title white">立即体验，快速开启数字出海之旅</h3>
			<div class="textAlign">
				<button class="button blue2 marginTop consultNow">立即咨询</button>
			</div>
		</div>
	</div>
	<!-- Quick experience html -->
	<!-- advantage html -->
	<div class="section-column white">
		<div class="section-screen">
			<h3 class="title">为什么选择我们?</h3>
			<div class="describe">
				<p>我们能为您提供怎样的价值</p>
			</div>
			<div class="choice-flex">
				<div class="choice-flex-item">
					<div class="image right"><img src="./assets/image/safety.png" /></div>
					<div class="text left">
						<div class="subtitle">价格美丽</div>
						<p class="describe"> 价格低于行业同类产品，无隐性支出，应用/模板等均无二次收费</p>

					</div>
				</div>
				<div class="choice-flex-item">
					<div class="image left"><img src="./assets/image/template.png" /></div>
					<div class="text right">
						<div class="subtitle">30+精品模板，轻松上手</div>
						<p class="describe">30+精品店铺模板, 适配不同产品场景, 无需设计经验或编码要求, 轻松满足个性化定制需求, 打造符合你的品牌风格的网上商城。
						</p>
					</div>
				</div>
				<div class="choice-flex-item">
					<div class="image right"><img src="./assets/image/service.png" /></div>
					<div class="text left">
						<div class="subtitle">专属客户服务群</div>
						<p class="describe">专属客户服务群，用心做好服务</p>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- advantage html -->


	<!-- intended for html -->
	<div class="section-column dark">
		<div class="section-screen">
			<h3 class="title">模板市场</h3>
			<div class="describe white">
				<p>海量的应用&模板供您选择</p>
				<!-- <p class="pc">用极致化的移动体验，打动每一个进站的消费者，让您的用户拥有流畅和愉悦的消费体验，获得不断提升的海外订单增长。</p>
