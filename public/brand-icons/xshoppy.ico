	<!-- customer html -->
	<div class="customer-fixed">
		<div class="webchat">
			<img src="./assets/image/wechat.svg" />
			<p>微信咨询</p>
			<div class="tips">
				<p class="describe">扫码添加</p>
				<p class="describe">微信号: Melody</p>
				<img src="./assets/image/webchat.jpg" />
			</div>
		</div>
		<div class="iphone ">
			<img src="./assets/image/phone.svg" />
			<p>电话咨询</p>
			<div class="tips tips-flex">
				<div class="image"><img src="./assets/image/phone.png" /></div>
				<div class="text">
					<a href="tel:13316414706">13316414706</a>
					<!-- <p>联系电话</p> -->
					<!-- <span></span> -->
				</div>
			</div>
		</div>
	</div>
	<div class="customer-mask"></div>
	<div class="customer-pop">
		<span class="close"></span>
		<div class="customer-header">
			<div class="image"><img src="./assets/image/customer01.png" /></div>
			<div class="text">
				<p>快速创建跨境独立站</p>
				<p>直链全球消费者</p>
			</div>
		</div>
		<img src="./assets/image/webchat.jpg" />
		<div class="contact">
			<div class="contact-item">
				<img src="./assets/image/webchat.png" />
				<spn>微信号： Melody</spn>
			</div>
			<div class="contact-item">
				<img src="./assets/image/phone.png" />
				<a href="tel:13316414706">13316414706</a>
			</div>
		</div>
	</div>
	<!-- customer html -->
	<div class="contact-form-mask fixed w-full h-full bg-black top-0 left-0 z-10 opacity-60 hidden"></div>
	<div class="contact-form-container fixed top-0 left-0 z-20 w-full h-full flex justify-center items-center hidden">
		<div class="contact-form-box relative w-full max-h-[96%] m-6 bg-white p-6 rounded-md shadow-xl md:w-[640px]">
			<div class="contact-form-close absolute right-3 top-3 hover:cursor-pointer">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
					stroke="currentColor" class="w-6 h-6">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</div>
			<div class="contact-header mb-8">
				<div class="text-2xl mb-2 mt-[-12px]">Contact Us.</div>
				<div class="text-base text-gray-600">Give us some info so the right person can get back to you.</div>
			</div>
			<form name="contact-form" class="contact-form overflow-auto">
				<div class="grid grid-cols-1 gap-4 gap-y-3 md:grid-cols-2">
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">First name</label>
						<input type="text" name="first_name" placeholder="First name"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" />
						<p class="form-error text-red-500 text-sm mt-1 hidden">Enter your first name</p>
					</div>
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">Last name</label>
						<input type="text" name="last_name" placeholder="Last name"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" />
						<p class="form-error text-red-500 text-sm mt-1 hidden">Enter your last name</p>
					</div>
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">Email</label>
						<input type="email" name="email" placeholder="Email"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" />
						<p class="form-error text-red-500 text-sm mt-1 hidden">Enter a valid email address</p>
					</div>
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">Phone</label>
						<input type="text" name="phone" placeholder="Phone"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" />
						<p class="form-error text-red-500 text-sm mt-1 hidden">Enter a valid phone number</p>
					</div>
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">Company</label>
						<input type="text" name="company" placeholder="Company"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" />
					</div>
					<div class="form-item">
						<label class="block text-sm font-medium leading-6 text-gray-900;">Country/Region</label>
						<select name="country"
							class="J-Value block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
							name="country"
							class="w-full py-2 px-2 rounded-md text-gray-400 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm">
							<option disabled="" label="Country/Region" selected="" value="">Country/Region</option>
							<option value="US">United States</option>
							<option value="AF">Afghanistan</option>
							<option value="AL">Albania</option>
							<option value="DZ">Algeria</option>
							<option value="AS">American Samoa</option>
							<option value="AD">Andorra</option>
