SCRAPIFY_BACKEND_BASE_URL=http://localhost:8787
SCRAPIFY_BACKEND_PREFIX=/api
# SCRAPIFY_BACKEND_TOKEN=

# === 后端运行时（Phase 0+） ===
# 数据库：默认走嵌入式 PGlite（无需 docker），数据持久到本地目录
# 切换到真 Postgres：DATABASE_URL=postgres://scrapify:scrapify_dev@localhost:5432/scrapify
DATABASE_URL=pglite://./.dev-pg-data

# Redis：默认走 ioredis-mock（无需 docker），仅当前进程内有效
# 切换到真 Redis：REDIS_URL=redis://localhost:6379
REDIS_URL=mock://

# 全局 IP 限流：每 IP 每窗口允许的最大请求数
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_WINDOW=1 minute
