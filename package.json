{
  "name": "scrapify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node scripts/clean-next.mjs",
    "predev": "node scripts/prepare-dev.mjs",
    "dev": "next dev",
    "dev:stop": "node scripts/stop-dev.mjs",
    "dev:restart": "node scripts/restart-dev.mjs",
    "dev:reset": "npm run dev:restart",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:dev": "npm run backend:build && node backend/dist/server.js",
    "backend:start": "npm run backend:build && node backend/dist/server.js",
    "backend:check": "tsc -p backend/tsconfig.json --noEmit",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate --config backend/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config backend/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config backend/drizzle.config.ts",
    "db:reset": "node -e \"const fs=require('fs'); fs.rmSync('.dev-pg-data',{recursive:true,force:true}); console.log('removed .dev-pg-data')\"",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "prod:up": "docker compose -f docker-compose.prod.yml --env-file .env up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f --tail 200",
    "prod:migrate": "docker compose -f docker-compose.prod.yml exec backend npx drizzle-kit migrate --config backend/drizzle.config.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@tanstack/react-query": "^5.76.2",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.8.5",
    "ioredis": "^5.4.2",
    "ioredis-mock": "^8.13.1",
    "lucide-react": "^0.511.0",
    "next": "^14.2.28",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.13.1",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^16.18.1",
    "tailwind-merge": "^3.3.0",
    "undici": "^6.25.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
