# ============================================================
# Scrapify 生产环境变量模板
# ============================================================
# 用法：cp .env.production.example .env  → 填值 → docker compose -f docker-compose.prod.yml up -d
#
# ⚠ 所有标 ★ 的变量必须填，留空会导致服务启动失败或鉴权链路断开。
# ⚠ 切勿把填好的 .env 提交到仓库。

# --- 域名（Caddy 用来申请 HTTPS 证书） ★ -------------------
# 必须先把这个域名的 A 记录指向本机公网 IP，否则 Let's Encrypt 申请失败
DOMAIN=scrapify.example.com

# --- NextAuth.js v5 ★ ---------------------------------------
# AUTH_URL 与 DOMAIN 保持一致（带 https://）
AUTH_URL=https://scrapify.example.com
# 生成命令：openssl rand -base64 32   或者：npx auth secret
AUTH_SECRET=

# Google OAuth：Cloud Console → API & Services → Credentials → OAuth 2.0 Client ID
# 授权回调 URL 必须填：https://scrapify.example.com/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- 前后端身份转发 HMAC 共享密钥 ★ -------------------------
# 前端 app/api/* 用此密钥签名 X-User-* header，后端 requireUser 验签
# 生成命令：openssl rand -base64 32
SCRAPIFY_BACKEND_HMAC_SECRET=

# --- Postgres ★ ---------------------------------------------
# ⚠ 密码会嵌入到 DATABASE_URL(postgres://scrapify:${POSTGRES_PASSWORD}@...),
# 必须只包含 [A-Za-z0-9],避免 URL 特殊字符如 @:/?# 导致连接串被截断。
# 推荐生成命令(已经过滤掉 = + /):
#   openssl rand -base64 24 | tr -d '=+/'
POSTGRES_PASSWORD=

# --- 后端 CORS Origin(可选,默认从 AUTH_URL 推导) -----------
# Compose 默认会让后端 BACKEND_CORS_ORIGIN=AUTH_URL,无需单独配。
# 如果前端域名与登录回调域名不同,在这里覆写为前端的 origin。
# ⚠ 必须是单一具体 origin,不允许 '*'(配合 credentials: true 浏览器会拒)
# BACKEND_CORS_ORIGIN=https://scrapify.example.com

# --- 限流（可选，留空走默认） -------------------------------
# 全局上限 200/min/user,敏感写入端点(POST /api/conversations/with-tasks 等)
# 通过路由级配置单独收紧到 20-30/min,无需在这里改。
# RATE_LIMIT_GLOBAL_PER_MIN=200
# RATE_LIMIT_WINDOW=1 minute
